import numpy as np

def isep_check(operator, tol=1e-8):
    """Check if operator satisfies Isep ≡ P_O = I."""
    eigvals, eigvecs = np.linalg.eigh(operator)
    span = eigvecs @ eigvecs.conj().T
    identity = np.eye(operator.shape[0])
    error = np.linalg.norm(span - identity)
    return error < tol, error
